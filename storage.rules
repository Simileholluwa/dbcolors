rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Strictly restrict access to Admins only.
    // User uploads for consultations are handled via temporary Signed URLs 
    // generated securely by the Cloud Functions using the Admin SDK.
    match /{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
