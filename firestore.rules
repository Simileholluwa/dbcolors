rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Strictly restrict Firestore access to Admins only.
    // The createBooking Cloud Function uses the Firebase Admin SDK
    // to bypass these rules and save consultation data securely.
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
